pipeline {
    agent any
    environment {
        IMAGE_NAME = "pidevfreelancy/challenge-service"
        IMAGE_TAG  = "latest"
        NAMESPACE  = "freelancy"
        KUBECTL    = "kubectl --kubeconfig=/var/jenkins_home/kubeconfig"
    }
    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('1 — Checkout Manifests') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/Challenge-Service']],
                    extensions: [
                        [
                            $class: 'CloneOption',
                            shallow: true,
                            depth: 1,
                            timeout: 30,
                            noTags: true
                        ],
                        [
                            $class: 'SparseCheckoutPaths',
                            sparseCheckoutPaths: [
                                [path: 'k8s/']
                            ]
                        ]
                    ],
                    userRemoteConfigs: [[
                        url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git',
                        credentialsId: 'github-credentials'
                    ]]
                ])
                echo 'Kubernetes manifests retrieved'
            }
        }
        stage('2 — Verify Image Docker Hub') {
            steps {
                sh "docker pull ${IMAGE_NAME}:${IMAGE_TAG}"
                echo "Image ${IMAGE_NAME}:${IMAGE_TAG} available on Docker Hub"
            }
        }
        stage('3 — Prepare Namespace & Secret') {
            steps {
                sh """
                    ${KUBECTL} create namespace ${NAMESPACE} \
                        --dry-run=client -o yaml | \
                    ${KUBECTL} apply --validate=false -f -
                """
                sh """
                    ${KUBECTL} create secret generic mysql-secret \
                        --from-literal=mysql-root-password=root \
                        -n ${NAMESPACE} \
                        --dry-run=client -o yaml | \
                    ${KUBECTL} apply --validate=false -f -
                """
                echo "Namespace and secrets ready"
            }
        }
        stage('4 — Deploy MySQL') {
        steps {
            sh "${KUBECTL} apply --validate=false -f k8s/mysql-deployment.yaml -n ${NAMESPACE}"
            sh "${KUBECTL} rollout status deployment/mysql-challenge -n ${NAMESPACE} --timeout=300s"
            echo "MySQL ready"
        }
        }
        stage('5 — Deploy Prometheus') {
            steps {
                sh "${KUBECTL} apply --validate=false -f k8s/prometheus-config.yaml -n ${NAMESPACE}"
                sh "${KUBECTL} apply --validate=false -f k8s/prometheus-deployment.yaml -n ${NAMESPACE}"
                echo "Prometheus deployed"
            }
        }
        stage('6 — Deploy Grafana') {
            steps {
                sh "${KUBECTL} apply --validate=false -f k8s/grafana-deployment.yaml -n ${NAMESPACE}"
                echo "Grafana deployed"
            }
        }
        stage('7 — Deploy Challenge Service') {
            steps {
                sh "${KUBECTL} apply --validate=false -f k8s/challenge-deployment.yaml -n ${NAMESPACE}"
                sh "${KUBECTL} rollout status deployment/challenge-deployment -n ${NAMESPACE} --timeout=300s"
                echo "Challenge service deployed"
            }
        }
        stage('8 — Smoke Test') {
            steps {
                sh "${KUBECTL} get pods -n ${NAMESPACE} -o wide"
                sh "${KUBECTL} get services -n ${NAMESPACE}"
                echo "Challenge API: http://192.168.49.2:30077/actuator/health"
                echo "Prometheus:    http://192.168.49.2:30090"
                echo "Grafana:       http://192.168.49.2:30030 (admin/admin123)"
            }
        }
    }
    post {
        success {
            echo '✅ CD Pipeline completed! All services deployed.'
        }
        failure {
            script {
                sh "${KUBECTL} get events -n ${NAMESPACE} --sort-by=.metadata.creationTimestamp | tail -20"
            }
            echo '❌ CD Pipeline failed!'
        }
        always {
            echo '🔄 CD Pipeline finished.'
        }
    }
}
