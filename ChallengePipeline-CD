pipeline {
    agent any
    environment {
        IMAGE_NAME = "ameni221/challenge-service"
        IMAGE_TAG  = "latest"
        NAMESPACE  = "freelancy"
    }
    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('1 — Checkout Manifests') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/Challenge-Service']],
                    extensions: [
                        [
                            $class: 'CloneOption',
                            shallow: true,
                            depth: 1,
                            timeout: 30,
                            noTags: true
                        ],
                        [
                            $class: 'SparseCheckoutPaths',
                            sparseCheckoutPaths: [
                                [path: 'k8s/']
                            ]
                        ]
                    ],
                    userRemoteConfigs: [[
                        url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git',
                        credentialsId: 'github-credentials'
                    ]]
                ])
                echo 'Kubernetes manifests retrieved'
            }
        }
        stage('2 — Verify Image Docker Hub') {
            steps {
                sh "docker pull ${IMAGE_NAME}:${IMAGE_TAG}"
                echo "Image ${IMAGE_NAME}:${IMAGE_TAG} available on Docker Hub"
            }
        }
        stage('3 — Create Namespace') {
            steps {
                sh "kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -"
                echo "Namespace ${NAMESPACE} ready"
            }
        }
        stage('4 — Deploy to Kubernetes') {
            steps {
                sh "kubectl apply -f k8s/challenge-deployment.yaml -n ${NAMESPACE}"
                echo "Manifests applied on K8s cluster"
            }
        }
        stage('5 — Verify Deployment') {
            steps {
                sh "kubectl rollout status deployment/challenge-deployment -n ${NAMESPACE} --timeout=120s"
                echo "Deployment is operational"
            }
        }
        stage('6 — Smoke Test') {
            steps {
                sh "kubectl get pods -n ${NAMESPACE} -o wide"
                sh "kubectl get services -n ${NAMESPACE}"
                echo "Verify manually: http://192.168.49.2:30077/actuator/health"
            }
        }
    }
    post {
        success {
            echo '✅ CD Pipeline completed! Challenge service is deployed.'
        }
        failure {
            script {
                sh "kubectl get events -n ${env.NAMESPACE} --sort-by=.metadata.creationTimestamp | tail -20"
            }
            echo '❌ CD Pipeline failed!'
        }
        always {
            echo '🔄 CD Pipeline finished.'
        }
    }
}