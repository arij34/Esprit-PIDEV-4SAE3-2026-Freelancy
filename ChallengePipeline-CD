pipeline {
    agent any

    environment {
        IMAGE_NAME      = "ameni221/freelancy-frontend"
        IMAGE_TAG       = "latest"
        NAMESPACE       = "freelancy"
        DEPLOYMENT_NAME = "frontend-deployment"
        DOCKER_CREDS    = credentials('docker-hub-credentials')
    }

    stages {

        stage('1 — Checkout Manifests') {
            steps {
                git(
                    url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git',
                    branch: 'Frontend-Devops',
                    credentialsId: 'github-credentials'
                )
                echo "✅ Manifests K8s récupérés"
            }
        }

        stage('2 — Verify Image on Docker Hub') {
            steps {
                sh "echo ${DOCKER_CREDS_PSW} | docker login -u ${DOCKER_CREDS_USR} --password-stdin"
                sh "docker pull ${IMAGE_NAME}:${IMAGE_TAG}"
                echo "✅ Image ${IMAGE_NAME}:${IMAGE_TAG} vérifiée sur Docker Hub"
            }
        }

        stage('3 — Deploy to Kubernetes') {
            steps {
                sh "kubectl apply -f k8s/"
                echo "✅ Manifests appliqués sur le cluster K8s"
            }
        }

        stage('4 — Wait for Rollout') {
            steps {
                sh "kubectl rollout restart deployment/${DEPLOYMENT_NAME} -n ${NAMESPACE}"
                sh "kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${NAMESPACE} --timeout=120s"
                echo "✅ Déploiement frontend opérationnel"
            }
        }

        stage('5 — Health Check') {
            steps {
                sh "kubectl get pods -n ${NAMESPACE} -l app=frontend"
                sh "kubectl get service frontend-service -n ${NAMESPACE}"
                echo "✅ Frontend accessible sur http://[IP_NODE]:30080"
            }
        }
    }

    post {
        success {
            echo "✅ CD réussi — Frontend accessible sur http://[IP_NODE]:30080"
        }
        failure {
            sh "kubectl get events -n ${NAMESPACE} --sort-by=.metadata.creationTimestamp | tail -20"
            echo "❌ CD échoué — voir les events K8s ci-dessus"
        }
    }
}