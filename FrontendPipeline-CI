pipeline {
    agent any

    tools {
        nodejs 'NodeJS-22'   
    }

    environment {
        IMAGE_NAME   = "ameni221/freelancy-frontend"
        IMAGE_TAG    = "latest"
        SERVICE_DIR  = "frontend"
        DOCKER_CREDS = credentials('docker-hub-credentials')
    }

    stages {

        stage('1 — Checkout') {
            steps {
                git(
                    url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git',
                    branch: 'Frontend-Devops',
                    credentialsId: 'github-credentials'
                )
                echo "✅ Code récupéré depuis GitHub — branche Frontend-Devops"
            }
        }

        stage('2 — Install Dependencies') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'node -v'     // confirms Node 22 is active
                    sh 'npm -v'      // confirms npm version
                    sh 'npm install'
                    echo "✅ npm install terminé"
                }
            }
        }

        stage('3 — Build Angular') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm run build -- --configuration production'
                    echo "✅ Build Angular terminé"
                }
            }
        }

        stage('4 — Docker Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    echo "✅ Image Docker construite : ${IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }

        stage('5 — Docker Push') {
            steps {
                sh "echo ${DOCKER_CREDS_PSW} | docker login -u ${DOCKER_CREDS_USR} --password-stdin"
                sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                echo "✅ Image publiée sur Docker Hub"
            }
        }
    }

    post {
        success {
            echo "✅ CI réussi — ${IMAGE_NAME}:${IMAGE_TAG} disponible sur Docker Hub"
        }
        failure {
            echo "❌ CI échoué — vérifier les logs"
        }
        always {
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
        }
    }
}