pipeline {
    agent any
    environment {
        DOCKER_IMAGE = "pidevfreelancy/event:latest"
        KUBECONFIG = "/var/lib/jenkins/.kube/config"
    }
    stages {
        stage('CLEAN') {
            steps { deleteDir() }
        }
        stage('GIT') {
            steps {
                git branch: 'event',
                    url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git',
                    credentialsId: 'github-token'
            }
        }
        stage('DEPLOY TO KUBERNETES') {
            steps {
                sh 'kubectl apply -f evenmentt1/k8s/namespace.yaml'
                sh 'kubectl apply -f evenmentt1/k8s/secret.yaml'
                sh 'kubectl apply -f evenmentt1/k8s/configmap.yaml'
                sh 'kubectl apply -f evenmentt1/k8s/mysql-deployment.yaml'
                sh 'kubectl apply -f evenmentt1/k8s/deployment.yaml'
                sh 'kubectl apply -f evenmentt1/k8s/service.yaml'
                sh 'kubectl rollout restart deployment/event-deployment -n freelancy'
            }
        }
        stage('VERIFY DEPLOYMENT') {
            steps {
                sh 'kubectl rollout status deployment/event-deployment -n freelancy --timeout=300s'
                sh 'kubectl get pods -n freelancy'
                sh 'kubectl get svc -n freelancy'
            }
        }
        stage('SMOKE TEST') {
            steps {
                sh 'kubectl get pods -n freelancy -o wide'
                sh 'kubectl get services -n freelancy'
                echo 'Event accessible via NodePort 30084'
            }
        }
    }
    post {
        success { echo 'Deploiement Kubernetes event reussi !' }
        failure {
            sh 'kubectl get events -n freelancy --sort-by=.metadata.creationTimestamp | tail -20'
            echo 'Deploiement Kubernetes event echoue !'
        }
    }
}
