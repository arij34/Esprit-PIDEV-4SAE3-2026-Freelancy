pipeline {
    agent any
    tools { maven "M2_HOME" }
    environment {
        DOCKER_IMAGE = "pidevfreelancy/event:latest"
    }
    stages {
        stage('GIT') {
            steps {
                git branch: 'event',
                    url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git',
                    credentialsId: 'github-token'
            }
        }
        stage('MVN CLEAN') {
            steps { dir('evenmentt1') { sh 'mvn clean' } }
        }
        stage('MVN COMPILE') {
            steps { dir('evenmentt1') { sh 'mvn compile' } }
        }
        stage('MVN TEST') {
            steps { dir('evenmentt1') { sh 'mvn test -DskipTests' } }
        }
        stage('MVN PACKAGE') {
            steps { dir('evenmentt1') { sh 'mvn package -DskipTests' } }
        }
        stage('JACOCO REPORT') {
            steps { dir('evenmentt1') { sh 'mvn jacoco:report' } }
        }
        stage('SONARQUBE ANALYSIS') {
            steps {
                dir('evenmentt1') {
                    withSonarQubeEnv('sonar') {
                        sh 'mvn sonar:sonar -Dsonar.projectKey=event -Dsonar.projectName=event -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml'
                    }
                }
            }
        }
        stage('DOCKER BUILD') {
            steps {
                dir('evenmentt1') {
                    sh 'docker build -t pidevfreelancy/event:latest .'
                }
            }
        }
        stage('DOCKER PUSH') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                    sh 'docker push pidevfreelancy/event:latest'
                }
            }
        }
    }
    post {
        success { echo 'event CI OK - image pidevfreelancy/event:latest pushed' }
        failure { echo 'event CI FAILED' }
    }
}
