pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "pidevfreelancy/eureka-service:latest"
        NAMESPACE    = "freelancy"
        KUBECONFIG   = "/var/jenkins_home/kubeconfig"
    }

    stages {

        stage('Git Checkout') {
            steps {
                git branch: 'eureka-server',
                    url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git'
            }
        }

        stage('Pull Latest Image') {
            steps {
                sh "docker pull ${DOCKER_IMAGE}"
            }
        }

        stage('Create Namespace') {
            steps {
                sh "kubectl --kubeconfig=/var/jenkins_home/kubeconfig create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl --kubeconfig=/var/jenkins_home/kubeconfig apply -f -"
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh "kubectl --kubeconfig=/var/jenkins_home/kubeconfig apply -f k8/eureka-deployment.yaml -n ${NAMESPACE}"
            }
        }

        stage('Verify Deployment') {
            steps {
                sh "kubectl --kubeconfig=/var/jenkins_home/kubeconfig rollout status deployment/eureka-deployment -n ${NAMESPACE} --timeout=180s"
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline completed successfully! Eureka service is deployed.'
        }
        failure {
            echo '❌ Pipeline failed! Check the logs above.'
            sh "kubectl --kubeconfig=/var/jenkins_home/kubeconfig get events -n ${NAMESPACE} --sort-by=.metadata.creationTimestamp | tail -10"
        }
        always {
            echo '🔄 CD Pipeline finished.'
        }
    }
}