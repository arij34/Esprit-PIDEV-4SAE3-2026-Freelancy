pipeline {
    agent any
    environment {
        IMAGE_NAME = "ameni221/api-gateway"
        IMAGE_TAG  = "latest"
        NAMESPACE  = "freelancy"
    }
    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('1 — Checkout Manifests') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/api-gateway']],
                    extensions: [
                        [
                            $class: 'CloneOption',
                            shallow: true,
                            depth: 1,
                            timeout: 30,
                            noTags: true
                        ],
                        [
                            $class: 'SparseCheckoutPaths',
                            sparseCheckoutPaths: [
                                [path: 'k8s/']
                            ]
                        ]
                    ],
                    userRemoteConfigs: [[
                        url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git',
                        credentialsId: 'github-credentials'
                    ]]
                ])
                echo 'API Gateway manifests retrieved'
            }
        }
        stage('2 — Verify Image Docker Hub') {
            steps {
                sh "docker pull ${IMAGE_NAME}:${IMAGE_TAG}"
                echo "Image ${IMAGE_NAME}:${IMAGE_TAG} available on Docker Hub"
            }
        }
        stage('3 — Prepare Namespace') {
            steps {
                sh "kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -"
                echo "Namespace ready"
            }
        }
        stage('4 — Deploy Prometheus') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/promotheus-grafana']],
                    extensions: [
                        [
                            $class: 'CloneOption',
                            shallow: true,
                            depth: 1,
                            timeout: 30,
                            noTags: true
                        ]
                    ],
                    userRemoteConfigs: [[
                        url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git',
                        credentialsId: 'github-credentials'
                    ]]
                ])
                sh "kubectl apply -f prometheus-config.yaml -n ${NAMESPACE}"
                sh "kubectl apply -f prometheus-deployment.yaml -n ${NAMESPACE}"
                echo "Prometheus deployed"
            }
        }
        stage('5 — Deploy Grafana') {
            steps {
                sh "kubectl apply -f grafana-deployment.yaml -n ${NAMESPACE}"
                echo "Grafana deployed"
            }
        }
        stage('6 — Checkout API Gateway Manifests Again') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/api-gateway']],
                    extensions: [
                        [
                            $class: 'CloneOption',
                            shallow: true,
                            depth: 1,
                            timeout: 30,
                            noTags: true
                        ],
                        [
                            $class: 'SparseCheckoutPaths',
                            sparseCheckoutPaths: [
                                [path: 'k8s/']
                            ]
                        ]
                    ],
                    userRemoteConfigs: [[
                        url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git',
                        credentialsId: 'github-credentials'
                    ]]
                ])
                echo 'API Gateway manifests re-retrieved'
            }
        }
        stage('7 — Deploy API Gateway') {
            steps {
                sh "kubectl apply -f k8s/api-gateway-deployment.yaml -n ${NAMESPACE}"
                sh "kubectl rollout status deployment/api-gateway-deployment -n ${NAMESPACE} --timeout=120s"
                echo "API Gateway deployed"
            }
        }
        stage('8 — Smoke Test') {
            steps {
                sh "kubectl get pods -n ${NAMESPACE} -o wide"
                sh "kubectl get services -n ${NAMESPACE}"
                echo "API Gateway: http://192.168.49.2:30091/actuator/health"
                echo "Prometheus:  http://localhost:30090"
                echo "Grafana:     http://localhost:30030 (admin/admin123)"
            }
        }
    }
    post {
        success {
            echo '✅ CD Pipeline completed! API Gateway deployed.'
        }
        failure {
            script {
                sh "kubectl get events -n ${env.NAMESPACE} --sort-by=.metadata.creationTimestamp | tail -20"
            }
            echo '❌ CD Pipeline failed!'
        }
        always {
            echo '🔄 CD Pipeline finished.'
        }
    }
}