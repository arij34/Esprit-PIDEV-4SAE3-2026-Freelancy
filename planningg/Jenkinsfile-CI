pipeline {
    agent any
    tools { maven "M2_HOME" }
    environment {
        DOCKER_IMAGE = "pidevfreelancy/planning:latest"
    }
    stages {
        stage('GIT') {
            steps {
                git branch: 'planning-management',
                    url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git',
                    credentialsId: 'github-token'
            }
        }
        stage('MVN CLEAN') {
            steps { dir('planningg') { sh 'mvn clean' } }
        }
        stage('MVN COMPILE') {
            steps { dir('planningg') { sh 'mvn compile' } }
        }
        stage('MVN TEST') {
            steps { dir('planningg') { sh 'mvn test' } }
        }
        stage('MVN PACKAGE') {
            steps { dir('planningg') { sh 'mvn package -DskipTests' } }
        }
        stage('JACOCO REPORT') {
            steps { dir('planningg') { sh 'mvn jacoco:report' } }
        }
        stage('SONARQUBE ANALYSIS') {
            steps {
                dir('planningg') {
                    withSonarQubeEnv('sonar') {
                        sh 'mvn sonar:sonar -Dsonar.projectKey=planning -Dsonar.projectName=planning -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml'
                    }
                }
            }
        }
        stage('DOCKER BUILD') {
            steps {
                dir('planningg') {
                    sh 'docker build -t pidevfreelancy/planning:latest .'
                }
            }
        }
        stage('DOCKER PUSH') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                    sh 'docker push pidevfreelancy/planning:latest'
                }
            }
        }
    }
    post {
        success { echo 'planning CI OK' }
        failure { echo 'planning CI FAILED' }
    }
}
