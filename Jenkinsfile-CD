pipeline {
    agent any
    environment {
        DOCKER_IMAGE = "arijachach/matching-module:latest"
        KUBECONFIG = "/var/jenkins_home/kubeconfig"
    }
    stages {
        stage('CLEAN') {
            steps {
                deleteDir()
            }
        }
        stage('GIT') {
            steps {
                git branch: 'Matching_Module',
                    url: 'https://github.com/arij34/Esprit-PIDEV-4SAE3-2026-Freelancy.git'
            }
        }
        stage('VERIFY IMAGE DOCKER HUB') {
            steps {
                sh "docker pull ${DOCKER_IMAGE}"
                echo "Image ${DOCKER_IMAGE} disponible sur Docker Hub"
            }
        }
        stage('DEPLOY TO KUBERNETES') {
            steps {
                sh '''
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig --validate=false apply -f k8s/namespace.yaml
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig --validate=false apply -f k8s/mysql-deployment.yaml
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig --validate=false apply -f k8s/configmap.yaml
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig --validate=false apply -f k8s/secret.yaml
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig --validate=false apply -f k8s/deployment.yaml
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig --validate=false apply -f k8s/service.yaml
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig rollout restart deployment/matching-deployment -n freelancy
                '''
            }
        }
        stage('VERIFY DEPLOYMENT') {
            steps {
                sh '''
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig rollout status deployment/matching-deployment -n freelancy --timeout=300s
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig get pods -n freelancy
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig get svc -n freelancy
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig get deployments -n freelancy
                '''
            }
        }
        stage('SMOKE TEST') {
            steps {
                sh '''
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig get pods -n freelancy -o wide
                    kubectl --kubeconfig=/var/jenkins_home/kubeconfig get services -n freelancy
                '''
                echo 'Service accessible via NodePort 30087'
            }
        }
    }
    post {
        success {
            echo 'Deploiement Kubernetes reussi !'
        }
        failure {
            sh '''
                kubectl --kubeconfig=/var/jenkins_home/kubeconfig get events -n freelancy --sort-by=.metadata.creationTimestamp | tail -20
            '''
            echo 'Deploiement Kubernetes echoue !'
        }
    }
}