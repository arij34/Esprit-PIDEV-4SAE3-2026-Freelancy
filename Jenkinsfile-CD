pipeline {
    agent any
    options {
        skipDefaultCheckout(true)
    }

    environment {
        K8S_NAMESPACE = 'freelancy'
        DOCKER_IMAGE = 'pidevfreelancy/blog-analytics-service:latest'
    }

    stages {
        stage('Checkout') {
            steps {
                dir('/home/vagrant/DEVOPS/blog-analytics-service') {
                    sh '[ -f k8s/deployment.yaml ] && [ -f k8s/service.yaml ]'
                }
            }
        }

        stage('Docker pull') {
            steps {
                dir('/home/vagrant/DEVOPS/blog-analytics-service') {
                    sh 'docker pull $DOCKER_IMAGE'
                }
            }
        }

        stage('Deploy to Kubernetes namespace freelancy') {
            steps {
                dir('/home/vagrant/DEVOPS/blog-analytics-service') {
                    sh 'KUBECONFIG=/home/vagrant/.kube/config minikube kubectl -- apply -f /home/vagrant/DEVOPS/k8s/namespace.yaml'
                    sh 'KUBECONFIG=/home/vagrant/.kube/config minikube kubectl -- apply -f k8s/deployment.yaml'
                    sh 'KUBECONFIG=/home/vagrant/.kube/config minikube kubectl -- apply -f k8s/service.yaml'
                }
            }
        }

        stage('Rollout status') {
            steps {
                dir('/home/vagrant/DEVOPS/blog-analytics-service') {
                    sh 'KUBECONFIG=/home/vagrant/.kube/config minikube kubectl -- rollout status deployment/blog-analytics-service-deployment -n $K8S_NAMESPACE --timeout=240s'
                }
            }
        }

        stage('Smoke test') {
            steps {
                dir('/home/vagrant/DEVOPS/blog-analytics-service') {
                    sh 'KUBECONFIG=/home/vagrant/.kube/config minikube kubectl -- get pods -n $K8S_NAMESPACE'
                    sh 'KUBECONFIG=/home/vagrant/.kube/config minikube kubectl -- get svc blog-analytics-service -n $K8S_NAMESPACE'
                    sh 'KUBECONFIG=/home/vagrant/.kube/config minikube kubectl -- get endpoints blog-analytics-service -n $K8S_NAMESPACE'
                }
            }
        }
    }
}
