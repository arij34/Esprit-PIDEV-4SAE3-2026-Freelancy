pipeline {
    agent any
    options {
        skipDefaultCheckout(true)
    }

    environment {
        K8S_NAMESPACE = 'freelancy'
        DOCKER_IMAGE = 'pidevfreelancy/blog-service:latest'
    }

    stages {
        stage('Checkout') {
            steps {
                dir('/home/vagrant/DEVOPS/blog-service') {
                    sh '[ -f k8s/deployment.yaml ] && [ -f k8s/service.yaml ]'
                }
            }
        }

        stage('Docker pull') {
            steps {
                dir('/home/vagrant/DEVOPS/blog-service') {
                    sh 'docker pull $DOCKER_IMAGE'
                }
            }
        }

        stage('Deploy to Kubernetes namespace freelancy') {
            steps {
                dir('/home/vagrant/DEVOPS/blog-service') {
                    sh 'minikube kubectl -- apply -f /home/vagrant/DEVOPS/k8s/namespace.yaml'
                    sh 'minikube kubectl -- apply -f k8s/deployment.yaml'
                    sh 'minikube kubectl -- apply -f k8s/service.yaml'
                }
            }
        }

        stage('Rollout status') {
            steps {
                dir('/home/vagrant/DEVOPS/blog-service') {
                    sh 'minikube kubectl -- rollout status deployment/blog-service-deployment -n $K8S_NAMESPACE --timeout=240s'
                }
            }
        }

        stage('Smoke test') {
            steps {
                dir('/home/vagrant/DEVOPS/blog-service') {
                    sh 'minikube kubectl -- run blog-service-smoke --rm --restart=Never -n $K8S_NAMESPACE --image=curlimages/curl:8.7.1 -- curl -fsS http://blog-service:8050/actuator/health'
                }
            }
        }
    }
}
